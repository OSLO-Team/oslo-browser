{
  "name": "oslo-browser",
  "version": "1.0.0-alpha.6",
  "description": "OSLO Browser - Elegant Electron-based Custom Web Browser",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --publish never && node scripts/write-checksums.js"
  },
  "keywords": [
    "browser",
    "electron",
    "oslo"
  ],
  "author": "OSLO Team",
  "license": "ISC",
  "build": {
    "appId": "com.oslo.browser",
    "productName": "OSLO Browser",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/logo.png",
      "sign": null,
      "publish": [
        {
          "provider": "github",
          "owner": "OSLO-Team",
          "repo": "oslo-browser"
        }
      ]
    },
    "nsis": {
      "artifactName": "OSLO-Browser-v${version}-Setup.exe",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OSLO Browser"
    }
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^25.1.8",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.17.3",
    "cross-fetch": "^4.1.0"
  }
}
